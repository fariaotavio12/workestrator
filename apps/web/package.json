{
  "name": "@workestrator/web",
  "private": true,
  "version": "0.0.0",
  "description": "Workestrator desktop and web client.",
  "author": "Otavio Faria",
  "desktopName": "Workestrator",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite --mode localhost",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:main": "tsc -b && vite build --mode main",
    "setup:api-local": "node scripts/setup-api-local.mjs",
    "design:sync": "node scripts/sync-design-md.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "npm run lint && npm run build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "claude:install": "npm exec --yes --package otavio-claude-config -- claude-config install",
    "mcp:server": "tsx electron/mcp-server/index.ts",
    "electron:build-main": "node scripts/build-electron.mjs",
    "electron:prepare-browser": "node scripts/prepare-playwright-browser.mjs",
    "electron:dev": "concurrently -k \"vite --mode localhost\" \"wait-on tcp:5173 && npm run electron:build-main && electron .\"",
    "electron:build": "tsc -b && vite build --mode electron && npm run electron:build-main && npm run electron:prepare-browser && electron-builder",
    "electron:release": "tsc -b && vite build --mode electron && npm run electron:build-main && npm run electron:prepare-browser && electron-builder --publish always"
  },
  "dependencies": {
    "@blocknote/core": "^0.41.1",
    "@blocknote/mantine": "^0.41.1",
    "@blocknote/react": "^0.41.1",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
