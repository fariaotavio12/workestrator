# ==========================================
# Workestrator API - Environment Variables Template
# ==========================================
# Copy this file to .env and fill the values.
# .env is gitignored — never commit real secrets.
# ==========================================

# ---------- Database ----------
DB_URL=jdbc:postgresql://host:5432/dbname
DB_USERNAME=
DB_PASSWORD=

# ---------- Auth ----------
APP_AUTH_GOOGLE_SUCCESS_REDIRECT=http://localhost:5173/auth/google/success
APP_AUTH_PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
APP_AUTH_ALLOWED_REDIRECT_HOSTS=localhost,127.0.0.1

# ---------- CORS ----------
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://workestrator.zappyon.com,http://localhost:5173,http://127.0.0.1:5173

# ---------- Google OAuth2 ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Mail (SMTP) ----------
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM_EMAIL=
APP_MAIL_FROM_NAME=

# ---------- AI (Anthropic) ----------
ANTHROPIC_API_KEY=

# ---------- AI Embeddings (RAG) ----------
# provider: voyage | openai. Dimensões: voyage-3=1024, openai text-embedding-3-small=1536.
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ---------- Optional Cloudflare R2 Storage ----------
# Disabled by default in application.properties. Fill these only if R2 storage is enabled there.
APP_STORAGE_CLOUDFLARE_ACCOUNT_ID=
APP_STORAGE_CLOUDFLARE_ACCESS_KEY_ID=
APP_STORAGE_CLOUDFLARE_SECRET_ACCESS_KEY=
APP_STORAGE_CLOUDFLARE_BUCKET=
APP_STORAGE_CLOUDFLARE_PUBLIC_URL_BASE=

# ---------- Optional Firebase ----------
# Base64-encoded Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ---------- Observability ----------
SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=

# ---------- Secret encryption ----------
# Base64 of 32 raw bytes. Example: openssl rand -base64 32
SECRETS_MASTER_KEY=
