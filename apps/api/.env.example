# ==========================================
# Gainz API - Environment Variables Template
# ==========================================
# Copy this file to .env and fill the values.
# .env is gitignored — never commit real secrets.
# ==========================================

# ---------- Database ----------
DB_URL=jdbc:postgresql://host:5432/dbname
DB_USERNAME=
DB_PASSWORD=
JPA_DDL_AUTO=update

# ---------- Auth ----------
APP_AUTH_COOKIE_NAME=AUTH_TOKEN
APP_AUTH_COOKIE_MAX_AGE=2592000
APP_AUTH_SESSION_DURATION_HOURS=720
APP_AUTH_SECURE_COOKIE=true
APP_AUTH_SAME_SITE=Lax
APP_AUTH_GOOGLE_SUCCESS_REDIRECT=http://localhost:5173/auth/google/success
APP_AUTH_PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
APP_AUTH_ALLOWED_REDIRECT_HOSTS=localhost,127.0.0.1
APP_AUTH_ALLOW_TOKEN_IN_QUERY_REDIRECT=true

# ---------- CORS ----------
APP_CORS_ALLOWED_ORIGIN_PATTERNS=*

# ---------- Google OAuth2 ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Mail (SMTP) ----------
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM_EMAIL=
APP_MAIL_FROM_NAME=
APP_MAIL_ENABLED=true

# ---------- AI (Anthropic) ----------
ANTHROPIC_API_KEY=

# ---------- AI Embeddings (RAG) ----------
# provider: voyage | openai. Dimensões: voyage-3=1024, openai text-embedding-3-small=1536.
APP_AI_EMBEDDINGS_PROVIDER=voyage
APP_AI_EMBEDDINGS_MODEL=voyage-3
APP_AI_EMBEDDINGS_DIMENSIONS=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ---------- Cloudflare R2 Storage ----------
APP_STORAGE_CLOUDFLARE_ENABLED=true
APP_STORAGE_CLOUDFLARE_ACCOUNT_ID=
APP_STORAGE_CLOUDFLARE_ACCESS_KEY_ID=
APP_STORAGE_CLOUDFLARE_SECRET_ACCESS_KEY=
APP_STORAGE_CLOUDFLARE_BUCKET=
APP_STORAGE_CLOUDFLARE_REGION=auto
APP_STORAGE_CLOUDFLARE_PUBLIC_URL_BASE=

# ---------- Firebase ----------
# Base64-encoded Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT_BASE64=
