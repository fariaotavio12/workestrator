# Dependencies
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# Build outputs
dist/
build/
release/
storybook-static/
dist-electron/
apps/*/dist/
apps/*/build/
apps/*/release/
apps/*/storybook-static/
apps/*/dist-electron/

# Local runtime output
orchestrator-workspace/
apps/*/orchestrator-workspace/

# Logs
*.log
codex-vite-*.log
vite-dev*.log

# Environment files
.env
.env.*
!.env.example
!apps/*/.env.example
# Mode-specific build targets are not secrets (just the prod API base URL) — must be committed so
# `vite build --mode main` / `--mode electron` bake in the real backend regardless of who builds it.
!apps/web/.env.main
!apps/web/.env.electron

# Tool caches
.gradle/
.kotlin/
apps/*/.gradle/
apps/*/.gradle-home/
apps/*/.kotlin/
.claude/settings.local.json
apps/*/.claude/settings.local.json
.turbo/
.vite/
.DS_Store
